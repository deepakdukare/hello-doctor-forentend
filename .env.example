# --- API CONFIG ---
# Backend API Base URL (trailing /api is usually correct)
# For local dev: http://localhost:5000/api
# For production: https://api.yourdomain.com/api
VITE_API_BASE_URL=http://localhost:5000/api

# --- FALLBACK ---
# Enable remote fallback for transient network errors (true/false)
VITE_ENABLE_REMOTE_FALLBACK=false

# --- DEV TOOLS ---
# Whether to show debug logs in console (only in development automatically)
# import.meta.env.DEV
